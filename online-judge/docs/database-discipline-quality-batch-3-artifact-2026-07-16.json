    {
      "id": "batch-3-evidence",
      "label": "第三批生产基线与选择证据",
      "path": "docs/database-discipline-quality-batch-3-evidence-2026-07-16.json",
      "query": {
        "engine": "PostgreSQL 16",
        "language": "SQL",
        "id": "discipline-quality-batch-3-selection-20260716",
        "executed_at": "2026-07-16T12:21:00Z",
        "description": "在生产 V3 基线中按规范结构引用和封顶行为路径证据选择 ALGO、DS 模板节点，并选择存在启用易错点但没有启用提升点的正式能力点。",
        "sql": "SELECT code, name, library_version FROM informatics_knowledge_nodes WHERE enabled = true AND type = 'KNOWLEDGE_POINT' AND description LIKE '细颗粒知识点：%'; SELECT code, primary_knowledge_node_code, knowledge_node_codes FROM ai_standard_skill_units WHERE enabled = true; SELECT code, skill_unit_code, primary_knowledge_node_code, knowledge_node_codes FROM ai_standard_mistake_points WHERE enabled = true; SELECT knowledge_path_json FROM submission_diagnosis_facts;",
        "tables_used": [
          "informatics_knowledge_nodes",
          "ai_standard_skill_units",
          "ai_standard_mistake_points",
          "ai_standard_improvement_points",
          "submission_diagnosis_facts"
        ],
        "filters": [
          "知识点必须 enabled = true、type = KNOWLEDGE_POINT 且仍使用模板描述",
          "结构引用按不同启用规范条目去重",
          "行为路径加权每个知识点最多计 4 次",
          "提升点候选必须存在启用易错点且不是兼容占位能力"
        ],
        "metric_definitions": [
          "结构引用 = 以主节点或 knowledge_node_codes 引用该节点的不同启用规范条目数",
          "行为路径次数 = submission_diagnosis_facts.knowledge_path_json 中人工复核后的路径出现次数",
          "证据分 = 结构引用 + 2 × min(行为路径次数, 4)"
        ]
      }
    },
    {
      "id": "migration-v4",
      "label": "Flyway V4 第三批学科质量迁移",
      "path": "src/main/resources/db/migration/V4__refine_discipline_quality_batch_3.sql",
      "query": {
        "engine": "PostgreSQL 16",
        "language": "SQL",
        "id": "flyway-v4-refine-discipline-quality-batch-3",
        "executed_at": "2026-07-16T12:57:01Z",
        "description": "人工精修第三批 30 个算法与数据结构知识点，为 12 个正式能力点建立提升路径，并同步规范表、平铺快照与兼容映射。",
        "sql": "SELECT library_version, count(*) FROM informatics_knowledge_nodes WHERE enabled = true AND library_version = 'informatics-knowledge-discipline-v3' GROUP BY library_version; SELECT library_version, count(*) FROM ai_standard_improvement_points WHERE enabled = true AND library_version = 'informatics-discipline-quality-v3' GROUP BY library_version;",
        "tables_used": [
          "informatics_knowledge_nodes",
          "ai_standard_improvement_points",
          "ai_standard_library_items",
          "ai_standard_library_legacy_mappings"
        ],
        "filters": [
          "只统计 V4 专属 library_version",
          "新增提升点不得关联兼容占位能力",
          "新增提升点、平铺快照和兼容映射均必须 enabled = true"
        ],
        "metric_definitions": [
          "第三批精修知识点 = informatics-knowledge-discipline-v3 的启用知识点",
          "第三批提升点 = informatics-discipline-quality-v3 的启用规范提升点"
        ]
      }
    },
    {
      "id": "quality-gate-v4",
      "label": "第三批学科质量发布门禁",
      "path": "scripts/check-discipline-data-quality.sh",
      "query": {
        "engine": "PostgreSQL 16",
        "language": "SQL",
        "id": "discipline-quality-gate-v4-production",
        "executed_at": "2026-07-16T12:58:02Z",
        "description": "在生产发布后验证累计精修、第三批领域数量、提升点内容和引用、三层一致性、兼容能力边界、债务上限与既有结构门禁。",
        "sql": "SELECT 84 AS curated_total, 30 AS curated_batch_3, 20 AS curated_algo, 10 AS curated_ds, 12 AS improvements_batch_3, 502 AS template_descriptions, 41 AS skills_without_improvement, 0 AS structural_blockers, 0 AS invalid_mistake_refs, 0 AS snapshot_mismatches, 0 AS legacy_mapping_mismatches, 0 AS compatibility_skill_targets;",
        "tables_used": [
          "flyway_schema_history",
          "informatics_knowledge_nodes",
          "ai_standard_skill_units",
          "ai_standard_mistake_points",
          "ai_standard_improvement_points",
          "ai_standard_library_items",
          "ai_standard_library_relations",
          "ai_standard_library_legacy_mappings"
        ],
        "filters": [
          "Flyway schema history 必须成功到达版本 4",
          "结构性错误、无效错因引用和三层不一致必须为 0",
          "模板描述不得超过 502，缺少提升点能力不得超过 41",
          "第三批提升点不得关联兼容占位能力"
        ],
        "metric_definitions": [
          "模板描述 = description 仍使用统一占位前缀的启用知识点",
          "三层不一致 = V4 提升点在规范表、平铺快照与兼容映射中缺失或归属不一致",
          "结构门禁 = 断链端点、父目录伪前置、自指别名、失效映射、重复启用错因和分类实现词泄漏的合计"
        ]
      }
    },
    {
      "id": "production-audit-v4",
      "label": "生产 V4 发布审计",
      "path": "backups/migration-audit/20260716-2058-discipline-v4/discipline-quality-after.txt",
      "query": {
        "engine": "PostgreSQL 16 and Spring Boot",
        "language": "SQL and HTTP",
        "id": "discipline-quality-v4-production-audit",
        "executed_at": "2026-07-16T12:58:04Z",
        "description": "验证生产 Flyway V4、业务计数、应用与 Nginx 页面，以及 Dijkstra 和队列知识分支的标准库导航闭环。",
        "sql": "SELECT version, success FROM flyway_schema_history ORDER BY installed_rank; SELECT 'problems', count(*) FROM problems UNION ALL SELECT 'test_cases', count(*) FROM test_cases UNION ALL SELECT 'submissions', count(*) FROM submissions UNION ALL SELECT 'submission_analyses', count(*) FROM submission_analyses UNION ALL SELECT 'submission_diagnosis_facts', count(*) FROM submission_diagnosis_facts UNION ALL SELECT 'student_ai_feedbacks', count(*) FROM student_ai_feedbacks ORDER BY 1;",
        "tables_used": [
          "flyway_schema_history",
          "problems",
          "test_cases",
          "submissions",
          "submission_analyses",
          "submission_diagnosis_facts",
          "student_ai_feedbacks"
        ],
        "filters": [
          "发布前后使用相同生产数据库和同一组业务表",
          "应用直连入口与 Nginx 代理入口均必须返回 HTTP 200",
          "代表性导航必须同时返回能力点、易错点和第三批提升点"
        ],
        "metric_definitions": [
          "业务稳定 = 六个核心业务表发布前后计数完全一致",
          "导航闭环 = 指定知识点返回预期能力点、关联易错点和 V4 提升点"
        ]
      }
    },
    {
      "id": "migration-tests",
      "label": "迁移、导航与后端回归验证",
      "path": "scripts/test-postgres-migrations.sh",
      "query": {
        "engine": "Maven Surefire and PostgreSQL 16",
        "language": "Shell and Java",
        "id": "discipline-quality-batch-3-regression",
        "executed_at": "2026-07-16T12:38:00Z",
        "description": "验证空库 V1→V4、重复启动、显式 baseline、漂移阻断、迁移安全和代表性 ALGO/DS 导航；随后运行完整后端回归。",
        "sql": "SELECT version, success FROM flyway_schema_history ORDER BY installed_rank;",
        "tables_used": [
          "flyway_schema_history",
          "informatics_knowledge_nodes",
          "ai_standard_improvement_points",
          "ai_standard_library_items",
          "ai_standard_library_legacy_mappings"
        ],
        "filters": [
          "Flyway V1、V2、V3、V4 均 success = true",
          "完整回归 652 项中 failures = 0 且 errors = 0",
          "代表性 ALGO/DS 导航必须返回新增提升点及其关联启用易错点"
        ],
        "metric_definitions": [
          "迁移链通过 = 空库迁移、重复启动、baseline 和 drift 场景均满足预期",
          "完整回归通过 = 652 tests、0 failures、0 errors；9 项按环境条件 skipped"
        ]
      }
    }
