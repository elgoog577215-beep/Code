SERVER_PORT=8081
APP_PROFILE=school
EXECUTOR_MODE=docker
OJ_APP_IMAGE=wenzhong-oj-app:latest
OJ_CPP17_DOCKER_IMAGE=wenzhong-oj-cpp17-runner:13
OJ_CPP17_BASE_IMAGE=gcc:13-bookworm
# If Docker Hub is blocked, try:
# OJ_CPP17_BASE_IMAGE=public.ecr.aws/docker/library/gcc:13-bookworm
OJ_PYTHON3_DOCKER_IMAGE=python:3.12-slim

POSTGRES_DB=onlinejudge
POSTGRES_USER=onlinejudge
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_JDBC_URL=jdbc:postgresql://postgres:5432/onlinejudge

TEACHER_PASSWORD=change-this-teacher-password
TEACHER_SESSION_SECRET=change-this-random-teacher-session-secret-at-least-32-chars
STUDENT_TOKEN_SECRET=change-this-random-student-token-secret-at-least-32-chars
TEACHER_SESSION_TTL_HOURS=12
STUDENT_TOKEN_TTL_DAYS=30

# Override these when the school network uses an internal registry or image mirror.
OJ_NODE_BASE_IMAGE=node:24-bookworm-slim
OJ_MAVEN_BASE_IMAGE=maven:3.9.9-eclipse-temurin-17
OJ_JRE_BASE_IMAGE=eclipse-temurin:17-jre
OJ_DOCKER_CLI_IMAGE=docker:29-cli
# Docker Hub fallback examples verified on this machine:
# OJ_NODE_BASE_IMAGE=public.ecr.aws/docker/library/node:24-bookworm-slim
# OJ_MAVEN_BASE_IMAGE=public.ecr.aws/docker/library/maven:3.9.9-eclipse-temurin-17
# OJ_JRE_BASE_IMAGE=public.ecr.aws/docker/library/eclipse-temurin:17-jre
# OJ_DOCKER_CLI_IMAGE=public.ecr.aws/docker/library/docker:29-cli

# 高中试点版默认要求外部 AI 可用；AI smoke 不通过时不建议开课。
AI_ENABLED=true
OJ_MODELSCOPE_API_KEY=
OJ_AI_BASE_URL=https://api-inference.modelscope.cn/v1
OJ_AI_MODEL=deepseek-ai/DeepSeek-V4-Flash
# auto: ModelScope 地址自动启用兼容请求；true: 强制启用；false: 使用标准 system/temperature/max_tokens 请求。
AI_MODELSCOPE_COMPATIBLE_REQUEST=auto
AI_READINESS_BLOCKING=true
AI_DIAGNOSIS_REPORT_V2_ENABLED=true
AI_MODEL_FAILURE_DEGRADE_ENABLED=true
AI_TIMEOUT_SECONDS=30
AI_EXTERNAL_RUNTIME_PROFILE=low-latency
AI_STREAM_ENABLED=true
AI_STREAM_FALLBACK_ENABLED=false
AI_STRUCTURED_RETRY_ENABLED=false
AI_RETRY_MAX_ATTEMPTS=1

# AI 搜索定位对照：默认关闭外部搜索定位模型调用，实时诊断走本地标准库包 + 单诊断 Agent。
AI_SEARCH_LOCATION_ENABLED=false
AI_SEARCH_LOCATION_MODE=hybrid
AI_SEARCH_LOCATION_CANDIDATE_LIMIT=120
AI_SEARCH_LOCATION_SELECTED_LIMIT=15
AI_SEARCH_REQUIRE_VECTOR=false
AI_SEARCH_TEXT_WEIGHT=0.45
AI_SEARCH_VECTOR_WEIGHT=0.35
AI_SEARCH_SIGNAL_WEIGHT=0.20

# 标准库向量召回：增强项，配置好 embedding key 后再显式开启。
AI_EMBEDDING_ENABLED=false
AI_EMBEDDING_MAINTENANCE_ENABLED=false
AI_EMBEDDING_BASE_URL=https://api-inference.modelscope.cn/v1
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
AI_EMBEDDING_TIMEOUT_SECONDS=20

# 标准库成长 Agent：默认只进入候选池，由教师确认后合并；自动入库默认关闭。
AI_STANDARD_LIBRARY_GROWTH_ENABLED=true
AI_STANDARD_LIBRARY_AUTO_MERGE_ENABLED=false
AI_STANDARD_LIBRARY_AUTO_MERGE_MIN_CONFIDENCE=0.90
